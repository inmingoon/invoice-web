# Notion 견적서 뷰어 — 환경 변수 템플릿
#
# 사용법:
#   cp .env.local.example .env.local
#   그리고 아래 키들의 값을 채운다. .env.local은 .gitignore에 등록되어 있어 커밋되지 않는다.
#
# 보안:
#   - 모든 값은 서버 전용이다. NEXT_PUBLIC_ 접두사를 절대 붙이지 말 것
#     (붙이는 순간 클라이언트 번들에 포함된다).
#   - 토큰 값은 어디에도 로깅하지 말 것. PRD §7 / lib/logger.ts 참고.

# Notion Internal Integration secret. https://www.notion.so/my-integrations 에서 발급.
NOTION_TOKEN=

# 견적서 데이터베이스의 page id (32자 hyphen 포함). DB URL의 마지막 segment.
NOTION_DATABASE_ID=

# Notion API v2 data source id. admin 목록/통계와 scripts/*.mjs가 사용.
# 미설정 시 NOTION_DATABASE_ID로 첫 data source를 자동 resolve (lib/notion.ts:getDataSourceId).
NOTION_DATA_SOURCE_ID=

# 로깅 레벨. debug | info | warn | error (기본: info)
LOG_LEVEL=info

# --- 관리자 인증 (ROADMAP.admin.md Phase A) ------------------------------------
# 관리자 비밀번호의 scrypt 해시. 생성:
#   node scripts/hash-password.mjs
# stdin에 비밀번호를 입력하면 stdout으로 해시 한 줄이 출력된다.
ADMIN_PASSWORD_HASH=

# JWT 서명 키 (≥32자). 외부 노출 금지. 생성 예:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
SESSION_SECRET=

# (선택) 링크 생성 시 base URL — Phase C link-generator가 사용. 예: https://invoice.example.com
NEXT_PUBLIC_SITE_URL=
